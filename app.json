{
  "expo": {
    "name": "Bếp thông minh",
    "currentFullName": "Bếp thông minh",
    "originalFullName": "Bếp thông minh",
    "slug": "smart-kitchen-vn",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "smart-kitchen-vn",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FEF0F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.smartkitchenvn"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FEF0F0"
      },
      "splash": {
        "image": "./assets/images/splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#FEF0F0"
      },
      "package": "com.anonymous.smartkitchenvn"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FEF0F0",
          "image": "./assets/images/splash.png",
          "dark": {
            "backgroundColor": "#FEF0F0",
            "image": "./assets/images/splash.png"
          },
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
